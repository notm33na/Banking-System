# ==============================================================================
# VIRTBANK — Combined .gitignore (Java/Maven + Node/React)
# ==============================================================================

# ── Java / Maven ──────────────────────────────────────────────────────────────
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# ── IDE (IntelliJ, VSCode, Eclipse) ──────────────────────────────────────────
.idea/
*.iws
*.iml
*.ipr
.vscode/
.settings/
.project
.classpath
.factorypath
bin/

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*~

# ── Env / Secrets ────────────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Node / React (frontend/) ────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.cache/
frontend/*.local

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Build artifacts ──────────────────────────────────────────────────────────
*.jar
*.war
*.class
